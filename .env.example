# BESTEMAIL PLATFORM - ENVIRONMENT REFERENCE
# Phase 2 foundation note:
# - Production core data paths are expected to use Supabase.
# - Local JSON fallback is intended for local/dev use only unless you explicitly opt in.

# Core app
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://bestemail.in
NEXTAUTH_URL=https://bestemail.in
SESSION_SECRET=generate-strong-random-session-secret-here
NEXTAUTH_SECRET=generate-random-secret-here-if-you-still-need-it
ENCRYPTION_KEY=generate-32-character-random-string-here
ADMIN_EMAIL=admin@bestemail.in
ADMIN_PASSWORD=generate-strong-unique-admin-password

# Supabase (required for predictable production data behavior)
# Use NEXT_PUBLIC_* on the client. SUPABASE_URL is accepted as a server alias.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_supabase_database_url

# Local data fallback control
# Default behavior:
# - development: enabled
# - production: disabled
# Set to true only if you intentionally want file-based fallback outside Supabase.
ALLOW_LOCAL_DATA_FALLBACK=false

# Sendy (required for email sending)
USE_SENDY=true
NEXT_PUBLIC_USE_SENDY=true
SENDY_API_URL=https://your-sendy-installation.com
SENDY_API_KEY=your_sendy_api_key
SENDY_LIST_ID=your_default_list_id
SENDY_BRAND_ID=1
DEFAULT_FROM_EMAIL=hello@bestemail.in
DEFAULT_FROM_NAME=Bestemail

# Optional SMS
INSTASENT_API_TOKEN=your_instasent_api_token
NEXT_PUBLIC_INSTASENT_API_TOKEN=your_instasent_api_token_for_client_testing_only

# White label / platform options
ENABLE_WHITE_LABEL=true
WHITE_LABEL_DOMAIN=bestemail.in

# Optional services
S3_BUCKET=bestemail-assets
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=ap-south-1
CDN_URL=https://cdn.bestemail.in
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_PROJECT_TOKEN=your_mixpanel_token
SENTRY_DSN=your_sentry_dsn
REDIS_URL=redis://localhost:6379
