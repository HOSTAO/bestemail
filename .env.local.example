# Local development example
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=change_me_session_secret
NEXTAUTH_SECRET=change_me
ENCRYPTION_KEY=change_me_32_chars_minimum
ADMIN_EMAIL=admin@bestemail.local
ADMIN_PASSWORD=change_me_admin_password

# Supabase (recommended even locally if you want production-like behavior)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=your_supabase_database_url

# Dev fallback defaults to enabled; keep explicit here for clarity
ALLOW_LOCAL_DATA_FALLBACK=true

# Sendy
USE_SENDY=true
NEXT_PUBLIC_USE_SENDY=true
SENDY_API_URL=https://my.bestemail.in
SENDY_API_KEY=your_sendy_api_key_from_settings
SENDY_LIST_ID=your_main_list_id
SENDY_BRAND_ID=1
DEFAULT_FROM_EMAIL=hello@bestemail.in
DEFAULT_FROM_NAME=Bestemail

# Optional SMS
INSTASENT_API_TOKEN=your_instasent_api_token
NEXT_PUBLIC_INSTASENT_API_TOKEN=your_instasent_api_token_for_client_testing_only

# Optional extras
ENABLE_WHITE_LABEL=true
WHITE_LABEL_DOMAIN=bestemail.in
S3_BUCKET=bestemail-assets
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=ap-south-1
CDN_URL=https://cdn.bestemail.in
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_PROJECT_TOKEN=your_mixpanel_token
